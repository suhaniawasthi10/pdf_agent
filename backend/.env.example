# Required — free key at https://console.groq.com (no credit card)
GROQ_API_KEY=gsk_...

# Models / retrieval
EMBEDDING_MODEL=BAAI/bge-m3
ANSWER_MODEL=llama-3.3-70b-versatile
TOP_K=6

# Local persistence
CHROMA_DIR=./data/chroma
UPLOAD_DIR=./data/uploads

# Comma-separated CORS origins. In prod, set to the deployed frontend URL,
# e.g. ALLOWED_ORIGINS=https://pdf-agent.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
